          }
        }
      '''
    }
  }
}

example {
  name: 409-Slug-Taken
  
  request: {
    url: {{base_url}}/api/tenants/register
    method: POST
    mode: json
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
        "slug": "lupitas",
        "name": "Café Lupita's",
        "email": "admin@lupitas.mx",
        "password": "12345678",
        "rfc": "LUPE123456ABC",
        "address": "Av. Principal 123, Col. Centro, CDMX",
        "phone": "+52 55 1234 5678",
        "ticketMessage": "¡Gracias por tu preferencia!",
        "ivaRate": 16,
        "paymentMethods": {
          "cash": true,
          "card": true,
          "qr": false,
          "transfer": false
        },
        "schedule": {
          "openTime": "08:00",
          "closeTime": "21:00",
          "openDays": [true, true, true, true, true, true, false]
        }
      }
    }
  }
  
  response: {
    status: {
      code: 409
      text: Conflict
    }
  
    body: {
      type: text
      content: '''
         {
          {
            "error": "SLUG_TAKEN",
            "message": "Ese nombre ya está en uso",
            "status": 409
          }
        }
      '''
    }
  }
}
